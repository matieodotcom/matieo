# Copy to .env.local and fill in values for local development
# ⚠️ Never commit .env.local

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=matieo-dev-unsigned

# Node API base URL (local dev)
VITE_API_URL=http://localhost:3001

# App environment — controls memorial URL prefix in Create Memorial page
# Values: development | production | (omit for local)
VITE_APP_ENV=
