# Frontend — Production Environment Variables
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to GitHub
# Set these in Hostinger panel or GitHub Actions secrets

# --- Supabase (PROD project) ---
VITE_SUPABASE_URL=https://your-prod-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-prod-anon-key

# --- Cloudinary (unsigned uploads, prod folder) ---
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=matieo-prod-unsigned

# --- Backend API ---
VITE_API_URL=https://matieo-api.onrender.com

# --- App ---
VITE_APP_ENV=production
VITE_APP_URL=https://yourdomain.com
