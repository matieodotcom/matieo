# Frontend — Development Environment Variables
# Copy this file to .env.development and fill in your values
# NEVER commit .env.development to GitHub

# --- Supabase (DEV project) ---
VITE_SUPABASE_URL=https://your-dev-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-dev-anon-key

# --- Cloudinary (unsigned uploads, dev folder) ---
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=matieo-dev-unsigned

# --- Backend API ---
VITE_API_URL=http://localhost:3001

# --- App ---
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173
