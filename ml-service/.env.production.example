# ML Service (Python) — Production Environment Variables
# Copy to .env.production — NEVER commit
# Set as Environment Variables in Render dashboard

APP_ENV=production
PORT=8000

# Supabase (service role)
SUPABASE_URL=https://your-prod-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key

# Shared secret with Node API
NODE_API_SECRET=your-prod-shared-secret

# Allowed origins (Node API Render URL only)
ALLOWED_ORIGINS=https://matieo-api.onrender.com
