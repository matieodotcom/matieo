# ML Service (Python) — Development Environment Variables
# Copy to .env.development — NEVER commit

APP_ENV=development
PORT=8000

# Supabase (service role — read mortality_data table)
SUPABASE_URL=https://your-dev-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

# Shared secret with Node API (must match backend ML_SERVICE_SECRET)
NODE_API_SECRET=your-shared-secret-between-node-and-ml

# Allowed origins (Node API URL)
ALLOWED_ORIGINS=http://localhost:3001
