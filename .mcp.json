{
  "mcpServers": {
    "supabase": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@supabase/mcp-server-supabase@latest", "--access-token", "${SUPABASE_ACCESS_TOKEN}"],
      "description": "Supabase DB — run SQL, manage tables, check schema, apply migrations"
    },

    "github": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
      },
      "description": "GitHub — create branches, commit, PR, push"
    },

    "figma": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@figma/mcp-server"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
      },
      "description": "Figma — read design specs, variables, layouts before building"
    },

    "context7": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@context7/mcp-server"],
      "description": "Library docs — check before using any framework API"
    },

    "cloudinary": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@cloudinary/mcp-server"],
      "env": {
        "CLOUDINARY_CLOUD_NAME": "${CLOUDINARY_CLOUD_NAME}",
        "CLOUDINARY_API_KEY": "${CLOUDINARY_API_KEY}",
        "CLOUDINARY_API_SECRET": "${CLOUDINARY_API_SECRET}"
      },
      "description": "Cloudinary — verify presets, manage media assets"
    },

    "resend": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "resend-mcp"],
      "env": {
        "RESEND_API_KEY": "${RESEND_API_KEY}"
      },
      "description": "Resend — send transactional emails, manage contacts, domains, broadcasts"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }
  }
}